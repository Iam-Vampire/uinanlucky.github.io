<aside id="sidebar" class="wiki-sidebar">
  <div class="sidebar-inner">
    <div class="widget-wrap" id="categories-wrap">
      <h3 class="widget-title">
        <span>分类</span>
        <a id="allExpand" href="#"><span class="icon-all-expand"></span></a>
      </h3>
      <% if (site.categories && site.categories.length) { %>
        <%
          var allCats = [];
          site.categories.sort('name').each(function(c) { allCats.push(c); });

          function findChildren(parentId) {
            return allCats.filter(function(c) {
              if (parentId) return c.parent && String(c.parent) === String(parentId);
              return !c.parent;
            });
          }

          function renderCatTree(parentId) {
            var children = findChildren(parentId);
            if (!children.length) return;
        %>
        <ul class="category-tree">
          <% children.forEach(function(cat) { %>
            <li class="directory">
              <a href="#" class="cat-toggle" data-target="cat-<%- cat._id %>">
                <svg class="icon-folder-closed" viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                  <path d="M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"/>
                </svg>
                <svg class="icon-folder-open" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" style="display:none">
                  <path d="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z"/>
                </svg>
                <%- cat.name %>
              </a>
              <ul id="cat-<%- cat._id %>" class="cat-articles">
                <% if (cat.posts && cat.posts.length) {
                  cat.posts.sort('date', -1).each(function(post) { %>
                    <li class="file<%- (is_post() && post._id == page._id) ? ' active' : '' %>">
                      <a href="<%- url_for(post.path) %>">
                        <svg class="icon-file" viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                          <path d="M6 2c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6H6zm0 18V4h7v5h5v11H6z"/>
                        </svg>
                        <%- post.title %>
                      </a>
                    </li>
                <% }); } %>
                <%- renderCatTree(cat._id) %>
              </ul>
            </li>
          <% }) %>
        </ul>
        <% } %>
        <% renderCatTree(null); %>
      <% } else { %>
        <p class="no-data" style="padding: 0.75rem; font-size: 0.85rem;">No categories yet.</p>
      <% } %>
    </div>
  </div>
  <div id="toTop" class="to-top">&#9650;</div>
</aside>

<script>
(function() {
  var wrap = document.getElementById('categories-wrap');
  if (!wrap) return;

  var allTrees = wrap.querySelectorAll('.cat-articles');
  allTrees.forEach(function(t) { t.style.display = 'none'; });
  wrap.querySelectorAll('.icon-folder-open').forEach(function(ic) { ic.style.display = 'none'; });
  wrap.querySelectorAll('.icon-folder-closed').forEach(function(ic) { ic.style.display = ''; });

  var activeFiles = wrap.querySelectorAll('.category-tree .file.active');
  if (activeFiles.length) {
    var deepest = activeFiles[0];
    var maxDepth = 0;
    activeFiles.forEach(function(f) {
      var d = 0;
      var p = f.parentElement;
      while (p && p !== wrap) {
        if (p.classList.contains('cat-articles')) d++;
        p = p.parentElement;
      }
      if (d > maxDepth) { maxDepth = d; deepest = f; }
    });
    var parentCat = deepest.closest('.cat-articles');
    while (parentCat) {
      parentCat.style.display = 'block';
      var parentDir = parentCat.closest('.directory');
      if (parentDir) {
        var openIcon = parentDir.querySelector('.icon-folder-open');
        var closedIcon = parentDir.querySelector('.icon-folder-closed');
        if (openIcon) openIcon.style.display = '';
        if (closedIcon) closedIcon.style.display = 'none';
      }
      parentCat = parentDir ? parentDir.closest('.cat-articles') : null;
    }
  }

  wrap.querySelectorAll('.cat-toggle').forEach(function(toggle) {
    toggle.addEventListener('click', function(e) {
      e.preventDefault();
      var targetId = this.getAttribute('data-target');
      var subtree = document.getElementById(targetId);
      if (!subtree) return;
      var expanded = subtree.style.display !== 'none' && subtree.style.display !== '';
      subtree.style.display = expanded ? 'none' : 'block';
      var openIcon = this.querySelector('.icon-folder-open');
      var closedIcon = this.querySelector('.icon-folder-closed');
      if (openIcon && closedIcon) {
        if (expanded) {
          openIcon.style.display = 'none';
          closedIcon.style.display = '';
        } else {
          openIcon.style.display = '';
          closedIcon.style.display = 'none';
        }
      }
    });
  });

  var allExpand = document.getElementById('allExpand');
  if (allExpand) {
    allExpand.addEventListener('click', function(e) {
      e.preventDefault();
      var trees = wrap.querySelectorAll('.cat-articles');
      var allHidden = true;
      trees.forEach(function(t) {
        if (t.style.display !== 'none' && t.style.display !== '') allHidden = false;
      });
      var expanded = trees.length > 0 && !allHidden;
      trees.forEach(function(tree) {
        tree.style.display = expanded ? 'none' : 'block';
      });
      wrap.querySelectorAll('.icon-folder-open').forEach(function(ic) {
        ic.style.display = expanded ? 'none' : '';
      });
      wrap.querySelectorAll('.icon-folder-closed').forEach(function(ic) {
        ic.style.display = expanded ? '' : 'none';
      });
    });
  }

  var toTop = document.getElementById('toTop');
  if (toTop) {
    toTop.addEventListener('click', function(e) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
})();
</script>
